<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <!-- No sandbox — required for CGEventTap and inheriting ANTHROPIC_API_KEY from shell env -->
    <key>com.apple.security.app-sandbox</key>
    <false/>
    <!-- Microphone for AVAudioEngine -->
    <key>com.apple.security.device.audio-input</key>
    <true/>
    <!-- Apple Speech Recognition -->
    <key>com.apple.security.personal-information.speech-recognition</key>
    <true/>
    <!-- Outbound network for Anthropic API -->
    <key>com.apple.security.network.client</key>
    <true/>
    <!-- Accessibility for global hotkey monitoring -->
    <key>com.apple.security.accessibility</key>
    <true/>
    <!-- Screen Recording: declared via NSScreenCaptureUsageDescription in Info.plist.
         No dedicated entitlement key needed for non-sandboxed apps. -->
</dict>
</plist>
